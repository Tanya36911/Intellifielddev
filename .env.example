# Copy this file to .env and fill in real values. .env is never committed.
# Docker Compose reads these to start the database and backend.

# Database password. Used by the db container and built into DATABASE_URL.
POSTGRES_PASSWORD=change-me

# Secret used to sign login wristbands (JWTs). Use a LONG, RANDOM value, unique
# per environment. Generate one with, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=generate-a-long-random-value

# Only needed when running the backend WITHOUT Docker. Inside Docker, Compose
# builds the right DATABASE_URL itself from POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://intelli:change-me@localhost:5432/intelli
